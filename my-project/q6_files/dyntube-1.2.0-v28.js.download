city: 0;\n    transition: visibility 1s, opacity 1s;\n}\n\n.dyt-controls-disabled .dyt-control-bar,\n.dyt-using-native-controls .dyt-control-bar,\n.dyt-error .dyt-control-bar {\n    display: none !important;\n}\n\n.dyt-audio.dyt-has-started.dyt-user-inactive.dyt-playing .dyt-control-bar {\n    opacity: 1;\n    visibility: visible;\n}\n\n.dyt-has-started.dyt-no-flex .dyt-control-bar {\n    display: table;\n}\n\n.dyntube-player .dyt-control {\n    position: relative;\n    text-align: center;\n    margin: 0;\n    padding: 0;\n    height: 100%; /*msa change, override this, as this creates errors.*/\n    width: 4em;\n    flex: none;\n}\n\n.dyt-button > .dyt-icon-placeholder:before {\n    font-size: 1.8em;\n    line-height: 1.67;\n}\n\n.dyntube-player .dyt-control:focus:before,\n.dyntube-player .dyt-control:hover:before,\n.dyntube-player .dyt-control:focus {\n    text-shadow: 0em 0em 1em white;\n}\n\n.dyntube-player .dyt-control-text {\n    border: 0;\n    clip: rect(0 0 0 0);\n    height: 1px;\n    overflow: hidden;\n    padding: 0;\n    position: absolute;\n    width: 1px;\n}\n\n.dyt-no-flex .dyt-control {\n    display: table-cell;\n    vertical-align: middle;\n}\n\n.dyntube-player .dyt-custom-control-spacer {\n    display: none;\n}\n\n.dyntube-player .dyt-progress-control {\n    cursor: pointer;\n    flex: auto;\n    display: flex;\n    align-items: center;\n    min-width: 4em;\n    touch-action: none;\n}\n\n    .dyntube-player .dyt-progress-control.disabled {\n        cursor: default;\n    }\n\n.dyt-live .dyt-progress-control {\n    display: none;\n}\n\n.dyt-liveui .dyt-progress-control {\n    display: flex;\n    align-items: center;\n}\n\n.dyt-no-flex .dyt-progress-control {\n    width: auto;\n}\n\n.dyntube-player .dyt-progress-holder {\n    flex: auto;\n    transition: all 0.2s;\n    height: 0.3em;\n}\n\n.dyntube-player .dyt-progress-control .dyt-progress-holder {\n    margin: 0 10px;\n}\n\n.dyntube-player .dyt-progress-control:hover .dyt-progress-holder {\n    font