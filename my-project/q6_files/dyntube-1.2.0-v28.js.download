   position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    opacity: 0;\n    transform: scale(0.5);\n    transition: none;\n}\n\n/* Modern glassmorphic background */\n.dyntube-player .dyt-flash-icon::before {\n    content: \'\';\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    background: rgba(255, 255, 255, 0.15);\n    backdrop-filter: blur(16px);\n    -webkit-backdrop-filter: blur(16px);\n    border-radius: 50%;\n    border: 2px solid rgba(255, 255, 255, 0.25);\n    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.2),\n                0 4px 16px rgba(255, 255, 255, 0.1) inset;\n}\n\n/* Icon styling */\n.dyntube-player .dyt-flash-icon [class^="dyt-icon-"] {\n    position: relative;\n    z-index: 1;\n    font-size: 64px;\n    color: inherit; /* Inherit from container */\n}\n\n.dyntube-player .dyt-flash-icon [class^="dyt-icon-"]:before {\n    display: inline-block;\n    width: 1em;\n    height: 1em;\n    mask-size: contain;\n    -webkit-mask-size: contain;\n    mask-repeat: no-repeat;\n    -webkit-mask-repeat: no-repeat;\n    mask-position: center;\n    -webkit-mask-position: center;\n    background-color: currentColor !important; /* Use currentColor like mobile gestures */\n    background-image: none !important;\n}\n\n/* ============================================\n   Visible State with Animation\n   ============================================ */\n\n.dyntube-player .dyt-flash-visible {\n    animation: dyt-flash-bounce 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);\n}\n\n@keyframes dyt-flash-bounce {\n    0% {\n        opacity: 0;\n        transform: scale(0.5);\n    }\n    15% {\n        opacity: 1;\n        transform: scale(1.15);\n    }\n    30% {\n        transform: scale(0.95);\n    }\n    45% {\n        transform: scale(1.05);\n    }\n    60% {\n        transform: scale(1);\n    }\n    85% {\n        opacity: 1;\n        transform: scale(1);\n    }\n    100% {\n        opacity: 0;\n        transform: scale(0.9);\n    }\n}\n\n/* ============================================\n   Responsive Sizing\n   ============================================ */\n\n/* Mobile / Small Screens */\n@media (max-width: 576px) {\n    .dyntube-player .dyt-flash-icon-container {\n        width: 110px;\n        height: 110px;\n    }\n\n    .dyntube-player .dyt-flash-icon [class^="dyt-icon-"] {\n        font-size: 48px;\n    }\n}\n\n/* Tablet */\n@media (min-width: 577px) and (max-width: 768px) {\n    .dyntube-player .dyt-flash-icon-container {\n        width: 120px;\n        height: 120px;\n    }\n\n    .dyntube-player .dyt-flash-icon [class^="dyt-icon-"] {\n        font-size: 52px;\n    }\n}\n\n/* Large Desktop */\n@media (min-width: 1024px) {\n    .dyntube-player .dyt-flash-icon-container {\n        width: 160px;\n        height: 160px;\n    }\n\n    .dyntube-player .dyt-flash-icon [class^="dyt-icon-"] {\n        font-size: 72px;\n    }\n}\n\n/* ============================================\n   Reduced Motion Support\n   ============================================ */\n\n@media (prefers-reduced-motion: reduce) {\n    .dyntube-player .dyt-flash-visible {\n        animation: dyt-flash-simple 0.5s ease;\n    }\n\n    @keyframes dyt-flash-simple {\n        0% {\n            opacity: 0;\n        }\n        20% {\n            opacity: 1;\n        }\n        80% {\n            opacity: 1;\n        }\n        100% {\n            opacity: 0;\n        }\n    }\n}\n\n/* ============================================\n   Fullscreen Adjustments\n   ============================================ */\n\n.dyntube-player.dyt-fullscreen .dyt-flash-icon-container {\n    width: 180px;\n    height: 180px;\n}\n\n.dyntube-player.dyt-fullscreen .dyt-flash-icon [class^="dyt-icon-"] {\n    font-size: 80px;\n}\n',""])},function(t,e){},function(t,e){},function(t,e,n){"use strict";(function(t){function i(){return t._babelPolyfill||"undefined"!=typeof 